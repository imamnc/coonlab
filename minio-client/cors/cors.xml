<CORSConfiguration>
	<CORSRule>
		<ID>Allow Content for olinvite.id</ID>
		<AllowedOrigin>https://www.olinvite.id</AllowedOrigin>
		<AllowedOrigin>http://www.olinvite.id</AllowedOrigin>
		<AllowedOrigin>https://olinvite.id</AllowedOrigin>
		<AllowedOrigin>http://olinvite.id</AllowedOrigin>
		<AllowedMethod>GET</AllowedMethod>
		<AllowedMethod>HEAD</AllowedMethod>
		<AllowedMethod>PUT</AllowedMethod>
		<AllowedMethod>POST</AllowedMethod>
		<AllowedMethod>DELETE</AllowedMethod>
		<AllowedHeader>*</AllowedHeader>
		<ExposeHeader>ETag</ExposeHeader>
		<MaxAgeSeconds>86400</MaxAgeSeconds>
	</CORSRule>
</CORSConfiguration>

